{
  "name": "@s-age/kernelee-devtools-bridge",
  "version": "0.5.0",
  "description": "WebSocket devtools bridge for kernelee: kernel-side connector + WS server (static asset serving included)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/s-age/kernelee-devtools-bridge.git"
  },
  "homepage": "https://github.com/s-age/kernelee-devtools-bridge",
  "keywords": [
    "kernelee",
    "devtools",
    "control-flow",
    "dispatch",
    "websocket"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css.ts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./connector": {
      "types": "./dist/connector.d.ts",
      "import": "./dist/connector.js"
    },
    "./trace-path": {
      "types": "./dist/tracePath.d.ts",
      "import": "./dist/tracePath.js"
    }
  },
  "bin": {
    "kernelee-devtools-bridge": "./dist/cli.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "build": "npm run vendor && npm run build:panel && tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "build:panel": "node scripts/build-panel.mjs",
    "vendor": "mkdir -p public/vendor && cp node_modules/relaph/dist/index.global.js public/vendor/relaph.global.js",
    "typecheck": "tsc --noEmit && tsc -p panel-src --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@s-age/kernelee": ">=0.5.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@s-age/kernelee": "^0.5.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.5.12",
    "@vanilla-extract/css": "^1.21.1",
    "@vanilla-extract/esbuild-plugin": "^2.3.22",
    "esbuild": "^0.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "relaph": "^0.4.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
